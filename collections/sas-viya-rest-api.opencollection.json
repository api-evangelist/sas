      "info": {
        "name": "Logon",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Obtain OAuth Access Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{viya-host}/SASLogon/oauth/token",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "grant_type",
                  "value": ""
                },
                {
                  "name": "username",
                  "value": ""
                },
                {
                  "name": "password",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Obtain OAuth Access Token"
        }
      ]
    },
    {
