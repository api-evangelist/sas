{
  "opencollection": "1.0.0",
  "info": {
    "name": "SAS Viya REST API",
    "version": "2024.10"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "resource_owner_password_credentials",
      "accessTokenUrl": "/SASLogon/oauth/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
